{
  "version": 2,
  "name": "quicktv-premium-proxy",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/quicktv-service/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/account-service/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/auth-service/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/user-service/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        },
        {
          "key": "Access-Control-Expose-Headers",
          "value": "*"
        }
      ]
    }
  ],
  "crons": [],
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "env": {
    "PREMIUM_USER_ID": "3377779474",
    "PREMIUM_AUTH_TOKEN": "25efe4b6de088d05c888",
    "PREMIUM_DEVICE_ID": "6caec8fc10dee519"
  },
  "regions": ["bom1"],
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x"
    }
  }
}
